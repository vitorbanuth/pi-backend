generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  email     String     @unique
  name      String?
  password  String
  age       Int?
  weight    Float?     // kg
  goal      String?    // e.g., "lose_weight", "maintain", "gain_muscle"
  foodLogs  FoodLog[]
  waterLogs WaterLog[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model FoodLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  imageUrl    String?  // URL from uploaded photo
  name        String   // Recognized food name or user-provided
  calories    Float    // Estimated or provided
  protein     Float?   // Optional macros
  carbs       Float?
  fat         Float?
  consumedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WaterLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  amountMl    Int      // Amount of water in ml
  loggedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
}
